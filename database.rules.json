{
  "rules": {
    "users": {
      "$uid": {
        ".read": "auth !== null && auth.uid === $uid",
        ".write": "auth !== null && auth.uid === $uid"
      }
    },
    "aiLimits": {
      "global": {
        ".read": false,
        ".write": false
      },
      "users": {
        "$uid": {
          ".read": "auth !== null && auth.uid === $uid",
          ".write": false
        }
      }
    }
  }
}
